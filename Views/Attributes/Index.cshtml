@using CvManagementSystem.ViewModels
@using CvManagementSystem.Entities
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@model IEnumerable<AttributeListViewModel>
@{
    ViewData["Title"] = L["AttributeLibrary"];
}

<div class="mb-3 d-flex flex-wrap gap-2">
    <a asp-action="Index"
       class="btn btn-sm @(ViewBag.SelectedCategory == null ? "btn-primary" : "btn-outline-primary")">
        @L["AllCategories"]
    </a>
    @foreach (var cat in Enum.GetValues<CvManagementSystem.Entities.AttributeCategory>())
    {
        <a asp-action="Index" asp-route-category="@cat"
           class="btn btn-sm @(ViewBag.SelectedCategory?.ToString() == cat.ToString() ? "btn-primary" : "btn-outline-primary")">
            @L[$"AttributeCategory_{cat}"]
        </a>
    }
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@L["AttributeLibrary"]</h2>
    <a asp-action="Create" class="btn btn-primary">@L["CreateAttribute"]</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        @L["NoAttributesYet"]
    </div>
}
else
{
    <div class="mb-2 d-flex gap-2 align-items-center" style="height:36px">
        <button type="button"
                id="deleteSelectedBtn"
                class="btn btn-danger btn-sm"
                style="visibility:hidden; opacity:0; transition: opacity 0.2s ease;">
            @L["DeleteSelected"]
        </button>
        <span id="selectedCount" class="text-muted small"></span>
    </div>

    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th style="width:40px">
                    <input type="checkbox" id="selectAll" class="form-check-input" />
                </th>
                <th>@L["NameLabel"]</th>
                <th>@L["CategoryLabel"]</th>
                <th>@L["DescriptionOptional"]</th>
                <th>@L["AttributeTypeLabel"]</th>
                <th>@L["OptionsCountLabel"]</th>
                <th>@L["CreatedByLabel"]</th>
                <th>@L["CreatedAtLabel"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="clickable-row"
                    data-href="@Url.Action("Details", new { id = item.Id })">
                    <td onclick="event.stopPropagation()">
                        <input type="checkbox"
                               class="form-check-input row-checkbox"
                               value="@item.Id" />
                    </td>
                    <td>
                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="text-decoration-none fw-bold">
                            @item.Name
                        </a>
                    </td>
                    <td> 
                        <span class="badge bg-primary">@L[$"AttributeCategory_{item.Category}"]</span>
                    </td>
                    <td>@(item.Description ?? L["EmptyValue"].Value)</td>
                    <td>
                        <span class="badge bg-secondary">@L[$"AttributeType_{item.Type}"]</span>
                    </td>
                    <td>
                        @if (item.Type == AttributeType.Dropdown)
                        {
                            <span>@item.OptionsCount</span>
                        }
                        else
                        {
                            <span>@L["EmptyValue"]</span>
                        }
                    </td>
                    <td>@item.CreatedByName</td>
                    <td>@item.CreatedAt.ToString("dd.MM.yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        document.querySelectorAll('.clickable-row').forEach(function(row) {
            row.style.cursor = 'pointer';
            row.addEventListener('click', function() {
                window.location.href = this.getAttribute('data-href');
            });
        });

        var selectAll = document.getElementById('selectAll');
        var deleteBtn = document.getElementById('deleteSelectedBtn');

        if (selectAll) {
            selectAll.addEventListener('change', function() {
                document.querySelectorAll('.row-checkbox').forEach(function(cb) {
                    cb.checked = this.checked;
                }.bind(this));
                updateToolbar();
            });
        }

        document.querySelectorAll('.row-checkbox').forEach(function(cb) {
            cb.addEventListener('change', updateToolbar);
        });

        if (deleteBtn) {
            deleteBtn.addEventListener('click', deleteSelected);
        }

        function updateToolbar() {
            var selected = document.querySelectorAll('.row-checkbox:checked');
            var countSpan = document.getElementById('selectedCount');

            if (selected.length > 0) {
                deleteBtn.style.visibility = 'visible';
                deleteBtn.style.opacity = '1';
                countSpan.textContent = '@Html.Raw(L["SelectedCount"].Value)'.replace('{0}', selected.length);
            } else {
                deleteBtn.style.visibility = 'hidden';
                deleteBtn.style.opacity = '0';
                countSpan.textContent = '';
            }
        }

        function deleteSelected() {
            var selected = document.querySelectorAll('.row-checkbox:checked');
            if (selected.length === 0) return;

            var confirmMsg = '@Html.Raw(L["DeleteConfirmBulk"].Value)'.replace('{0}', selected.length);
            if (!confirm(confirmMsg)) return;

            var form = document.createElement('form');
            form.method = 'post';
            form.action = '/Attributes/DeleteMultiple';

            selected.forEach(function(cb) {
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'ids';
                input.value = cb.value;
                form.appendChild(input);
            });

            document.body.appendChild(form);
            form.submit();
        }
    </script>
}