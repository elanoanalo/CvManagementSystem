@using CvManagementSystem.Entities
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@model CvManagementSystem.ViewModels.AttributeFormViewModel
@{
    ViewData["Title"] = L["CreateAttribute"];
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="mb-4">@L["CreateAttribute"]</h2>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">@L["NameLabel"]</label>
                        <input asp-for="Name" class="form-control"
                               placeholder="@L["AttributeNamePlaceholder"]" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">
                            @L["DescriptionOptional"]
                        </label>
                        <textarea asp-for="Description" class="form-control"
                                  rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Type" class="form-label">@L["AttributeTypeLabel"]</label>
                        <select asp-for="Type"
                                class="form-select"
                                id="typeSelect"
                                asp-items="@(Enum.GetValues<AttributeType>().Select(t => new SelectListItem { Value = ((int)t).ToString(), Text = L[$"AttributeType_{t}"] }))">
                        </select>
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>



                    <div id="optionsBlock" style="display:none">
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h5 class="card-title">@L["DropdownOptions"]</h5>
                                <p class="text-muted small">
                                    @L["AddOptionPrompt"]
                                </p>

                                <div id="optionsList">
                                </div>

                                <div class="input-group mt-2">
                                    <input type="text"
                                           id="newOptionInput"
                                           class="form-control"
                                           placeholder="@L["EnterOptionPlaceholder"]" />
                                    <button type="button"
                                            class="btn btn-outline-primary"
                                            onclick="addOption()">
                                        @L["AddButton"]
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
    <label asp-for="Category" class="form-label">@L["CategoryLabel"]</label>
    <select asp-for="Category" class="form-select"
            asp-items="@(Enum.GetValues<AttributeCategory>().Select(c => new SelectListItem { Value = ((int)c).ToString(), Text = L[$"AttributeCategory_{c}"] }))">
    </select>
</div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@L["CreateButton"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["CancelButton"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var optionCount = 0;

        var typeSelect = document.getElementById('typeSelect');
        var optionsBlock = document.getElementById('optionsBlock');

        typeSelect.addEventListener('change', function() {
            var dropdownValue = "@Json.Serialize((int)AttributeType.Dropdown)";
            if (this.value === dropdownValue) {
                optionsBlock.style.display = 'block';
            } else {
                optionsBlock.style.display = 'none';
            }
        });

        function addOption() {
            var input = document.getElementById('newOptionInput');
            var value = input.value.trim();

            if (value === '') return;

            var optionsList = document.getElementById('optionsList');

            var div = document.createElement('div');
            div.className = 'input-group mb-2';
            div.innerHTML =
                '<input type="text" ' +
                'name="Options[' + optionCount + ']" ' +
                'value="' + value + '" ' +
                'class="form-control" />' +
                '<button type="button" ' +
                'class="btn btn-outline-danger" ' +
                'onclick="this.parentElement.remove()">✕</button>';

            optionsList.appendChild(div);
            optionCount++;
            input.value = '';
            input.focus();
        }

        document.getElementById('newOptionInput')
            .addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    addOption();
                }
            });
    </script>
}
