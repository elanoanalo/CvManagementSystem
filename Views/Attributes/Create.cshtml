@using CvManagementSystem.Entities
@using CvManagementSystem.Extensions
@model CvManagementSystem.ViewModels.AttributeFormViewModel
@{
    ViewData["Title"] = "Создать атрибут";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="mb-4">Создать атрибут</h2>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Название</label>
                        <input asp-for="Name" class="form-control"
                               placeholder="Например: GPA, English Level" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">
                            Описание (необязательно)
                        </label>
                        <textarea asp-for="Description" class="form-control"
                                  rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Type" class="form-label">Тип атрибута</label>
                        <select asp-for="Type"
                                class="form-select"
                                id="typeSelect"
                                asp-items="@Html.GetEnumSelectList(typeof(AttributeType))">
                        </select>
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>

                    @* Блок вариантов — показывается только для Dropdown *@
                    <div id="optionsBlock" style="display:none">
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h5 class="card-title">Варианты выбора</h5>
                                <p class="text-muted small">
                                    Добавьте варианты которые увидит кандидат
                                </p>

                                <div id="optionsList">
                                    @* Варианты добавляются через JS *@
                                </div>

                                <div class="input-group mt-2">
                                    <input type="text"
                                           id="newOptionInput"
                                           class="form-control"
                                           placeholder="Введите вариант..." />
                                    <button type="button"
                                            class="btn btn-outline-primary"
                                            onclick="addOption()">
                                        Добавить
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Создать</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var optionCount = 0;

        var typeSelect = document.getElementById('typeSelect');
        var optionsBlock = document.getElementById('optionsBlock');

        typeSelect.addEventListener('change', function () {
            if (this.value === '7') {
                optionsBlock.style.display = 'block';
            } else {
                optionsBlock.style.display = 'none';
            }
        });

        function addOption() {
            var input = document.getElementById('newOptionInput');
            var value = input.value.trim();

            if (value === '') return;

            var optionsList = document.getElementById('optionsList');

            var div = document.createElement('div');
            div.className = 'input-group mb-2';
            div.innerHTML =
                '<input type="text" ' +
                'name="Options[' + optionCount + ']" ' +
                'value="' + value + '" ' +
                'class="form-control" />' +
                '<button type="button" ' +
                'class="btn btn-outline-danger" ' +
                'onclick="this.parentElement.remove()">✕</button>';

            optionsList.appendChild(div);
            optionCount++;
            input.value = '';
            input.focus();
        }

        document.getElementById('newOptionInput')
            .addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    addOption();
                }
            });
    </script>
}