@using Microsoft.Extensions.Localization
@using System.Text.Encodings.Web
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@inject HtmlEncoder Encoder
@model CvManagementSystem.ViewModels.PositionListViewModel
@{
    ViewData["Title"] = L["PositionTitlePrefix", Model.Title];
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Title</h2>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">@L["EditBtn"]</a>
            <a asp-action="Duplicate" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                @L["DuplicateBtn"]
            </a>
            <a asp-action="Candidates" asp-route-id="@Model.Id" class="btn btn-success">
                @L["ViewCvsCountBtn", Model.CvsCount]
            </a>
            <form asp-action="Delete"
                  asp-route-id="@Model.Id"
                  method="post"
                  onsubmit="return confirm('@Json.Serialize(L["DeletePositionConfirm"].Value)')">
                <button type="submit" class="btn btn-danger">@L["DeleteBtn"]</button>
            </form>
        }
        @if (User.IsInRole("Candidate"))
        {
            @if (ViewBag.ExistingCvId != null)
            {
                <a asp-controller="Cv" asp-action="ViewCv" asp-route-id="@ViewBag.ExistingCvId"
                   class="btn btn-success">
                    @L["OpenMyCvBtn"]
                </a>
            }
            else if (Model.IsPublished)
            {
                <a asp-controller="Cv" asp-action="CreateConfirm" asp-route-positionId="@Model.Id"
                   class="btn btn-primary">
                    @L["CreateCvForPositionBtn"]
                </a>
            }
        }
        <a asp-action="Index" class="btn btn-outline-secondary">@L["CancelButton"]</a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow mb-3">
            <div class="card-body">
                <h5 class="card-title">@L["GeneralInfoTitle"]</h5>
                <table class="table table-borderless">
                    <tr>
                        <th style="width:200px">@L["TitleColumnLabel"]</th>
                        <td>@Model.Title</td>
                    </tr>
                    <tr>
                        <th>@L["DescriptionColumnLabel"]</th>
                        <td>@(Model.Description ?? @L["EmptyValue"])</td>
                    </tr>
                    <tr>
                        <th>@L["StatusColumnLabel"]</th>
                        <td>
                            @if (Model.IsPublished)
                            {
                                <span class="badge bg-success">@L["PublishedState"]</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@L["DraftState"]</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>@L["TagsLabel"]</th>
                        <td>
                            @foreach (var tag in Model.Tags)
                            {
                                <span class="badge bg-info text-dark me-1">@tag</span>
                            }
                            @if (!Model.Tags.Any())
                            {
                                <span class="text-muted">@L["EmptyValue"]</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>@L["CreatedByColumnLabel"]</th>
                        <td>@Model.CreatedByName</td>
                    </tr>
                    <tr>
                        <th>@L["CreationDateColumnLabel"]</th>
                        <td>@Model.CreatedAt.ToString("g", System.Globalization.CultureInfo.CurrentCulture)</td>
                    </tr>
                    <tr>
                        <th>@L["CvCreatedCountLabel"]</th>
                        <td>@Model.CvsCount</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body">
                <h5 class="card-title">@L["PositionAttributesLabel"]</h5>
                @if (ViewBag.Attributes.Count == 0)
                {
                    <p class="text-muted">@L["NoAttributesAlert"]</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var attr in ViewBag.Attributes)
                        {
                            <li class="list-group-item px-0">
                                <div class="d-flex align-items-center gap-2">
                                    <span>@attr.Name</span>
                                    <span class="badge bg-secondary">@L[$"AttributeType_{attr.Type}"]</span>
                                    @if (attr.IsRequired)
                                    {
                                        <span class="badge bg-danger ms-auto">@L["RequiredAttributeBadge"]</span>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>