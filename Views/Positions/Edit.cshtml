@using Microsoft.Extensions.Localization
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@model CvManagementSystem.ViewModels.PositionFormViewModel
@{
    ViewData["Title"] = L["EditPositionTitle"];
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="mb-4">@L["EditPositionTitle"]</h2>

                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    <input type="hidden" asp-for="RowVersion" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">@L["PositionTitleLabel"]</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">
                            @L["DescriptionOptional"]
                        </label>
                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="3"></textarea>
                    </div>

                    @* Теги *@
                    <div class="mb-4">
                        <label class="form-label">@L["TagsLabel"]</label>
                        <div id="tagsList" class="mb-2 d-flex flex-wrap gap-2">
                            @for (int i = 0; i < Model.Tags.Count; i++)
                            {
                                <div class="d-inline-flex align-items-center tag-item">
                                    <input type="hidden"
                                           name="Tags[@i]"
                                           value="@Model.Tags[i]" />
                                    <span class="badge bg-info text-dark me-1">
                                        @Model.Tags[i]
                                        <button type="button"
                                                class="btn-close btn-close-white ms-1"
                                                style="font-size:0.6rem">
                                        </button>
                                    </span>
                                </div>
                            }
                        </div>
                        <div class="input-group">
                            <input type="text"
                                   id="newTagInput"
                                   class="form-control"
                                   placeholder="@L["AddTagPlaceholder"]" />
                            <button type="button"
                                    id="addTagBtn"
                                    class="btn btn-outline-primary">
                                @L["AddTagBtn"]
                            </button>
                        </div>
                    </div>

                    @* Атрибуты *@
                    <div class="mb-4">
                        <label class="form-label">@L["PositionAttributesLabel"]</label>

                        <div id="selectedAttributes" class="mb-3">
                            @for (int i = 0; i < Model.Attributes.Count; i++)
                            {
                                var attr = Model.Attributes[i];
                                <div class="card mb-2 attr-card"
                                     data-attr-id="@attr.AttributeDefinitionId">
                                    <div class="card-body py-2 d-flex align-items-center gap-3">
                                        <input type="hidden"
                                               name="Attributes[@i].AttributeDefinitionId"
                                               value="@attr.AttributeDefinitionId" />
                                        <input type="hidden"
                                               name="Attributes[@i].DisplayOrder"
                                               value="@i" />
                                        <span class="fw-bold">@attr.AttributeName</span>
                                        <span class="badge bg-secondary">@L[$"AttributeType_{attr.AttributeType}"]</span>
                                        <div class="form-check ms-2">
                                            <input type="checkbox"
                                                   name="Attributes[@i].IsRequired"
                                                   value="true"
                                                   class="form-check-input"
                                                   id="req-@i"
                                            @(attr.IsRequired ? "checked" : "") />
                                            <label class="form-check-label" for="req-@i">
                                                @L["RequiredBadge"]
                                            </label>
                                        </div>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger ms-auto remove-attr-btn">
                                            @L["RemoveBtn"]
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="card bg-light">
                            <div class="card-body">
                                <h6>@L["AvailableAttributesHeader"]</h6>
                                @foreach (var attr in Model.AvailableAttributes)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary me-1 mb-1 add-attr-btn"
                                            data-attr-id="@attr.Id"
                                            data-attr-name="@attr.Name"
                                            data-attr-type="@attr.Type">
                                        + @attr.Name
                                        <span class="badge bg-secondary ms-1">@L[$"AttributeType_{attr.Type}"]</span>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    @* Статус публикации *@
                    <div class="mb-3">
                        <label class="form-label">@L["PublicationStatusLabel"]</label>
                        <div class="d-flex align-items-center gap-3 p-3 border rounded">
                            <div class="form-check form-switch mb-0">
                                <input asp-for="IsPublished"
                                       class="form-check-input"
                                       type="checkbox"
                                       role="switch"
                                       id="isPublishedSwitch"
                                       style="width:3em; height:1.5em; cursor:pointer" />
                            </div>
                            <div>
                                <div id="publishLabel" class="fw-bold"></div>
                                <div id="publishDescription" class="text-muted small"></div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MaxProjectsInCv" class="form-label">@L["MaxProjectsLabel"]</label>
                        <input asp-for="MaxProjectsInCv" type="number" min="0" max="20"
                               class="form-control" style="max-width:150px" />
                        <small class="text-muted d-block">@L["MaxProjectsHint"]</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@L["SaveButton"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["CancelButton"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/tag-input.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initTagInput({
                maxTags: 10,
                maxTagLength: 50,
                duplicateMessage: '@Html.Raw(L["JsTagDuplicateError"].Value)',
                lengthMessage: '@Html.Raw(L["JsTagLengthError"].Value)',
                maxMessage: '@Html.Raw(L["JsMaxTagsError"].Value)'
            });
        });
    </script>

    <script>
        var attributeCount = @Model.Attributes.Count;
        var addedAttributeIds = [];

        var publishedText = '@Html.Raw(L["PublishedState"].Value)';
        var draftText = '@Html.Raw(L["DraftState"].Value)';
        var publishedDesc = '@Html.Raw(L["PublishedDescription"].Value)';
        var draftDesc = '@Html.Raw(L["DraftDescription"].Value)';
        var alreadyAddedMsg = '@Html.Raw(L["JsAttributeAlreadyAdded"].Value)';

        // Заполняем уже добавленные атрибуты
        document.querySelectorAll('.attr-card').forEach(function(card) {
            addedAttributeIds.push(card.getAttribute('data-attr-id'));
        });


        // ===== АТРИБУТЫ =====

        function addAttribute(id, name, type) {
            if (addedAttributeIds.indexOf(id) !== -1) {
                alert(alreadyAddedMsg);
                return;
            }
            addedAttributeIds.push(id);

            var container = document.getElementById('selectedAttributes');
            var div = document.createElement('div');
            div.className = 'card mb-2 attr-card';
            div.setAttribute('data-attr-id', id);
            div.innerHTML =
                '<div class="card-body py-2 d-flex align-items-center gap-3">' +
                '<input type="hidden" name="Attributes[' + attributeCount + '].AttributeDefinitionId" value="' + id + '" />' +
                '<input type="hidden" name="Attributes[' + attributeCount + '].DisplayOrder" value="' + attributeCount + '" />' +
                '<span class="fw-bold">' + name + '</span>' +
                '<span class="badge bg-secondary">' + type + '</span>' +
                '<div class="form-check ms-2">' +
                '<input type="checkbox" name="Attributes[' + attributeCount + '].IsRequired" value="true" class="form-check-input" id="req-' + attributeCount + '" />' +
                '<label class="form-check-label" for="req-' + attributeCount + '">@L["RequiredBadge"]</label>' +
                '</div>' +
                '<button type="button" class="btn btn-sm btn-outline-danger ms-auto remove-attr-btn">@L["RemoveBtn"]</button>' +
                '</div>';

            container.appendChild(div);
            attributeCount++;
        }

        document.querySelectorAll('.add-attr-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                addAttribute(
                    this.getAttribute('data-attr-id'),
                    this.getAttribute('data-attr-name'),
                    this.getAttribute('data-attr-type')
                );
            });
        });

        document.getElementById('selectedAttributes').addEventListener('click', function(e) {
            if (e.target.classList.contains('remove-attr-btn')) {
                var card = e.target.closest('.attr-card');
                var id = card.getAttribute('data-attr-id');
                var index = addedAttributeIds.indexOf(id);
                if (index !== -1) addedAttributeIds.splice(index, 1);
                card.remove();
            }
        });

        // ===== ПЕРЕКЛЮЧАТЕЛЬ ПУБЛИКАЦИИ =====

        var publishSwitch = document.getElementById('isPublishedSwitch');
        var publishLabelEl = document.getElementById('publishLabel');
        var publishDescEl = document.getElementById('publishDescription');

        function updatePublishUI() {
            if (publishSwitch.checked) {
                publishLabelEl.textContent = publishedText;
                publishLabelEl.className = 'fw-bold text-success';
                publishDescEl.textContent = publishedDesc;
            } else {
                publishLabelEl.textContent = draftText;
                publishLabelEl.className = 'fw-bold text-warning';
                publishDescEl.textContent = draftDesc;
            }
        }

        updatePublishUI();
        publishSwitch.addEventListener('change', updatePublishUI);
    </script>
}
