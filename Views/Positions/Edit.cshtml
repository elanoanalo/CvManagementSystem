
@model CvManagementSystem.ViewModels.PositionFormViewModel
@{
    ViewData["Title"] = "Редактировать позицию";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="mb-4">Редактировать позицию</h2>

                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Название позиции</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">
                            Описание (необязательно)
                        </label>
                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="3"></textarea>
                    </div>



                    @* Теги *@
                    <div class="mb-4">
                        <label class="form-label">Теги</label>
                        <div id="tagsList" class="mb-2 d-flex flex-wrap gap-2">
                            @for (int i = 0; i < Model.Tags.Count; i++)
                            {
                                <div class="d-inline-flex align-items-center tag-item">
                                    <input type="hidden"
                                           name="Tags[@i]"
                                           value="@Model.Tags[i]" />
                                    <span class="badge bg-info text-dark me-1">
                                        @Model.Tags[i]
                                        <button type="button"
                                                class="btn-close btn-close-white ms-1"
                                                style="font-size:0.6rem">
                                        </button>
                                    </span>
                                </div>
                            }
                        </div>
                        <div class="input-group">
                            <input type="text"
                                   id="newTagInput"
                                   class="form-control"
                                   placeholder="Добавить тег..." />
                            <button type="button"
                                    id="addTagBtn"
                                    class="btn btn-outline-primary">
                                Добавить тег
                            </button>
                        </div>
                    </div>

                    @* Атрибуты *@
                    <div class="mb-4">
                        <label class="form-label">Атрибуты позиции</label>

                        <div id="selectedAttributes" class="mb-3">
                            @for (int i = 0; i < Model.Attributes.Count; i++)
                            {
                                var attr = Model.Attributes[i];
                                <div class="card mb-2 attr-card"
                                     data-attr-id="@attr.AttributeDefinitionId">
                                    <div class="card-body py-2 d-flex align-items-center gap-3">
                                        <input type="hidden"
                                               name="Attributes[@i].AttributeDefinitionId"
                                               value="@attr.AttributeDefinitionId" />
                                        <input type="hidden"
                                               name="Attributes[@i].DisplayOrder"
                                               value="@i" />
                                        <span class="fw-bold">@attr.AttributeName</span>
                                        <span class="badge bg-secondary">@attr.AttributeType</span>
                                        <div class="form-check ms-2">
                                            <input type="checkbox"
                                                   name="Attributes[@i].IsRequired"
                                                   value="true"
                                                   class="form-check-input"
                                                   id="req-@i"
                                            @(attr.IsRequired ? "checked" : "") />
                                            <label class="form-check-label" for="req-@i">
                                                Обязательный
                                            </label>
                                        </div>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger ms-auto remove-attr-btn">
                                            Убрать
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="card bg-light">
                            <div class="card-body">
                                <h6>Доступные атрибуты из библиотеки:</h6>
                                @foreach (var attr in Model.AvailableAttributes)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary me-1 mb-1 add-attr-btn"
                                            data-attr-id="@attr.Id"
                                            data-attr-name="@attr.Name"
                                            data-attr-type="@attr.Type">
                                        + @attr.Name
                                        <span class="badge bg-secondary ms-1">@attr.Type</span>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Статус публикации</label>
                        <div class="d-flex align-items-center gap-3 p-3 border rounded">
                            <div class="form-check form-switch mb-0">
                                <input asp-for="IsPublished"
                                       class="form-check-input"
                                       type="checkbox"
                                       role="switch"
                                       id="isPublishedSwitch"
                                       style="width:3em; height:1.5em; cursor:pointer" />
                            </div>
                            <div>
                                <div id="publishLabel" class="fw-bold"></div>
                                <div id="publishDescription" class="text-muted small"></div>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Сохранить</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Счётчики для правильной индексации полей
        var tagCount = @Model.Tags.Count;
        var attributeCount = @Model.Attributes.Count;

        // ID уже добавленных атрибутов — чтобы не добавить дважды
        var addedAttributeIds = [];

        // Заполняем список уже добавленных атрибутов из существующих карточек
        document.querySelectorAll('.attr-card').forEach(function (card) {
            addedAttributeIds.push(card.getAttribute('data-attr-id'));
        });

        // ===== ТЕГИ =====

        function addTag() {
            var input = document.getElementById('newTagInput');
            var value = input.value.trim();

            if (value === '') return;

            var tagsList = document.getElementById('tagsList');

            var div = document.createElement('div');
            div.className = 'd-inline-flex align-items-center tag-item';
            div.innerHTML =
                '<input type="hidden" name="Tags[' + tagCount + ']" value="' + value + '" />' +
                '<span class="badge bg-info text-dark me-1">' + value +
                ' <button type="button" class="btn-close btn-close-white ms-1 remove-tag-btn" style="font-size:0.6rem"></button>' +
                '</span>';

            tagsList.appendChild(div);
            tagCount++;
            input.value = '';
            input.focus();
        }

        // Кнопка "Добавить тег"
        document.getElementById('addTagBtn')
            .addEventListener('click', function () {
                addTag();
            });

        // Enter в поле тега
        document.getElementById('newTagInput')
            .addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    addTag();
                }
            });

        // Удаление тега — через делегирование событий
        document.getElementById('tagsList')
            .addEventListener('click', function (e) {
                if (e.target.classList.contains('remove-tag-btn') ||
                    e.target.classList.contains('btn-close')) {
                    e.target.closest('.tag-item').remove();
                }
            });

        // ===== АТРИБУТЫ =====

        function addAttribute(id, name, type) {
            if (addedAttributeIds.indexOf(id) !== -1) {
                alert('Этот атрибут уже добавлен!');
                return;
            }

            addedAttributeIds.push(id);

            var container = document.getElementById('selectedAttributes');

            var div = document.createElement('div');
            div.className = 'card mb-2 attr-card';
            div.setAttribute('data-attr-id', id);
            div.innerHTML =
                '<div class="card-body py-2 d-flex align-items-center gap-3">' +
                '<input type="hidden" name="Attributes[' + attributeCount + '].AttributeDefinitionId" value="' + id + '" />' +
                '<input type="hidden" name="Attributes[' + attributeCount + '].DisplayOrder" value="' + attributeCount + '" />' +
                '<span class="fw-bold">' + name + '</span>' +
                '<span class="badge bg-secondary">' + type + '</span>' +
                '<div class="form-check ms-2">' +
                '<input type="checkbox" ' +
                'name="Attributes[' + attributeCount + '].IsRequired" ' +
                'value="true" ' +
                'class="form-check-input" ' +
                'id="req-' + attributeCount + '" />' +
                '<label class="form-check-label" for="req-' + attributeCount + '">Обязательный</label>' +
                '</div>' +
                '<button type="button" class="btn btn-sm btn-outline-danger ms-auto remove-attr-btn">Убрать</button>' +
                '</div>';

            container.appendChild(div);
            attributeCount++;
        }

        // Кнопки "Добавить атрибут" — через делегирование событий
        document.querySelectorAll('.add-attr-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var id = this.getAttribute('data-attr-id');
                var name = this.getAttribute('data-attr-name');
                var type = this.getAttribute('data-attr-type');
                addAttribute(id, name, type);
            });
        });

        // Кнопки "Убрать атрибут" — через делегирование событий
        document.getElementById('selectedAttributes')
            .addEventListener('click', function (e) {
                if (e.target.classList.contains('remove-attr-btn')) {
                    var card = e.target.closest('.attr-card');
                    var id = card.getAttribute('data-attr-id');

                    var index = addedAttributeIds.indexOf(id);
                    if (index !== -1) {
                        addedAttributeIds.splice(index, 1);
                    }

                    card.remove();
                }
            });

                    // Переключатель публикации
        var publishSwitch = document.getElementById('isPublishedSwitch');
        var publishLabel = document.getElementById('publishLabel');
        var publishDescription = document.getElementById('publishDescription');

        function updatePublishUI() {
            if (publishSwitch.checked) {
                publishLabel.textContent = 'Опубликовано';
                publishLabel.className = 'fw-bold text-success';
                publishDescription.textContent = 'Позиция видна кандидатам';
            } else {
                publishLabel.textContent = 'Черновик';
                publishLabel.className = 'fw-bold text-warning';
                publishDescription.textContent = 'Позиция скрыта от кандидатов';
            }
        }

        // Инициализируем при загрузке страницы
        updatePublishUI();

        // Обновляем при переключении
        publishSwitch.addEventListener('change', function () {
            updatePublishUI();
        });
    </script>
}