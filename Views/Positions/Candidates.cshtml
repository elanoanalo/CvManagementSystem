@using CvManagementSystem.ViewModels
@model IEnumerable<CvListViewModel>
@{
    ViewData["Title"] = "CV кандидатов — " + ViewBag.PositionTitle;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>CV для позиции: @ViewBag.PositionTitle</h2>
    <a asp-controller="Positions"
       asp-action="Details"
       asp-route-id="@ViewBag.PositionId"
       class="btn btn-outline-secondary">
        ← Назад к позиции
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Пока ни один кандидат не создал CV для этой позиции.
    </div>
}
else
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Кандидат</th>
                <th>Дата создания CV</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cv in Model)
            {
                <tr class="clickable-row"
                    data-href="@Url.Action("ViewCv", "Cv", new { id = cv.Id })">
                    <td class="fw-bold">@cv.PositionTitle</td>
                    <td>@cv.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        document.querySelectorAll('.clickable-row').forEach(function (row) {
            row.style.cursor = 'pointer';
            row.addEventListener('click', function () {
                window.location.href = this.getAttribute('data-href');
            });
        });
    </script>
}