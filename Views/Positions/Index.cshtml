@using CvManagementSystem.ViewModels
@model IEnumerable<PositionListViewModel>
@{
    ViewData["Title"] = "Позиции";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Позиции</h2>
    <a asp-action="Create" class="btn btn-primary">Создать позицию</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Позиций пока нет. Создайте первую!
    </div>
}
else
{
    <form id="bulkForm" method="post">
        <div class="mb-2 d-flex gap-2 align-items-center" style="height:36px">
            <button type="button"
                    id="deleteSelectedBtn"
                    class="btn btn-danger btn-sm"
                    style="visibility:hidden; opacity:0; transition: opacity 0.2s ease;">
                Удалить выбранные
            </button>
            <span id="selectedCount" class="text-muted small"></span>
        </div>

        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th style="width:40px">
                        <input type="checkbox"
                               id="selectAll"
                               class="form-check-input" />
                    </th>
                    <th>Название</th>
                    <th>Теги</th>
                    <th>Атрибутов</th>
                    <th>CV</th>
                    <th>Статус</th>
                    <th>Создал</th>
                    <th>Дата</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var position in Model)
                {
                    <tr class="clickable-row"
                        data-href="@Url.Action("Details", new { id = position.Id })">
                        <td onclick="event.stopPropagation()">
                            <input type="checkbox"
                                   class="form-check-input row-checkbox"
                                   value="@position.Id" />
                        </td>
                        <td>
                            <a asp-action="Details"
                               asp-route-id="@position.Id"
                               class="text-decoration-none fw-bold">
                                @position.Title
                            </a>
                        </td>
                        <td>
                            @foreach (var tag in position.Tags)
                            {
                                <span class="badge bg-info text-dark me-1">@tag</span>
                            }
                        </td>
                        <td>@position.AttributesCount</td>
                        <td>@position.CvsCount</td>
                        <td>
                            @if (position.IsPublished)
                            {
                                <span class="badge bg-success">Опубликована</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Черновик</span>
                            }
                        </td>
                        <td>@position.CreatedByName</td>
                        <td>@position.CreatedAt.ToString("dd.MM.yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </form>
}

@section Scripts {
    <script>
        document.querySelectorAll('.clickable-row').forEach(function (row) {
            row.style.cursor = 'pointer';
            row.addEventListener('click', function () {
                window.location.href = this.getAttribute('data-href');
            });
        });

        document.getElementById('selectAll')
            .addEventListener('change', function () {
                var checkboxes = document.querySelectorAll('.row-checkbox');
                checkboxes.forEach(function (cb) {
                    cb.checked = this.checked;
                }.bind(this));
                updateToolbar();
            });

        document.querySelectorAll('.row-checkbox').forEach(function (cb) {
            cb.addEventListener('change', function () {
                updateToolbar();
            });
        });

                    // САМО УДАЛЕНИЕ ЧЕРЕЗ ЧЕКБОКСЫ
        document.getElementById('deleteSelectedBtn')
            .addEventListener('click', function () {
                deleteSelected();
            });

        function updateToolbar() {
            var selected = document.querySelectorAll('.row-checkbox:checked');
            var deleteBtn = document.getElementById('deleteSelectedBtn');
            var countSpan = document.getElementById('selectedCount');

            if (selected.length > 0) {
                deleteBtn.style.visibility = 'visible';
                deleteBtn.style.opacity = '1';
                countSpan.textContent = 'Выбрано: ' + selected.length;
            } else {
                deleteBtn.style.visibility = 'hidden';
                deleteBtn.style.opacity = '0';
                countSpan.textContent = '';
            }
        }

        function deleteSelected() {
            var selected = document.querySelectorAll('.row-checkbox:checked');
            if (selected.length === 0) return;

            if (!confirm('Удалить выбранные позиции (' + selected.length + ' шт.)?'))
                return;

            selected.forEach(function (cb) {
                var form = document.createElement('form');
                form.method = 'post';
                form.action = '/Positions/Delete/' + cb.value;
                document.body.appendChild(form);
                form.submit();
            });
        }
    </script>
}