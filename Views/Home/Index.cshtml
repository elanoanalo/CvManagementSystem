@using Microsoft.Extensions.Localization
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@{
    ViewData["Title"] = L["HomeTitle"];
}

<div class="row g-3 mb-4">
    <div class="col-md-4 col-sm-6">
        <div class="card shadow text-center h-100">
            <div class="card-body">
                <div class="display-4 fw-bold text-primary">
                    @ViewBag.TotalPositions
                </div>
                <div class="text-muted">@L["OpenPositionsStat"]</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card shadow text-center h-100">
            <div class="card-body">
                <div class="display-4 fw-bold text-success">
                    @ViewBag.TotalCvs
                </div>
                <div class="text-muted">@L["TotalCvsStat"]</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card shadow text-center h-100">
            <div class="card-body">
                <div class="display-4 fw-bold text-warning">
                    @ViewBag.NewCvsLast24Hours
                </div>
                <div class="text-muted">@L["NewCvs24hStat"]</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card shadow text-center h-100">
            <div class="card-body">
                <div class="display-4 fw-bold text-info">
                    @ViewBag.TotalCandidates
                </div>
                <div class="text-muted">@L["CandidatesStat"]</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card shadow text-center h-100">
            <div class="card-body">
                <div class="display-4 fw-bold text-secondary">
                    @ViewBag.TotalRecruiters
                </div>
                <div class="text-muted">@L["RecruitersStat"]</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card shadow text-center h-100">
            <div class="card-body">
                <div class="display-4 fw-bold text-danger">
                    @ViewBag.TotalAttributes
                </div>
                <div class="text-muted">@L["LibraryAttributesStat"]</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">

    <div class="col-md-6">
        <div class="card shadow h-100">
            <div class="card-body">
                <h5 class="card-title mb-3">@L["RecentPositionsHeader"]</h5>
                @if (ViewBag.RecentPositions.Count == 0)
                {
                    <p class="text-muted">@L["NoPositionsYet"]</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var position in ViewBag.RecentPositions)
                        {
                            <li class="list-group-item px-0">
                                <a asp-controller="Positions"
                                   asp-action="Details"
                                   asp-route-id="@position.Id"
                                   class="text-decoration-none fw-bold">
                                    @position.Title
                                </a>
                                <div class="mt-1">
                                    @foreach (var tag in position.Tags)
                                    {
                                        <span class="badge bg-info text-dark me-1">
                                            @tag.Tag
                                        </span>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                    <div class="mt-2">
                        <a asp-controller="Positions"
                           asp-action="Index"
                           class="btn btn-outline-primary btn-sm">
                            @L["AllPositionsBtn"]
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow h-100">
            <div class="card-body">
                <h5 class="card-title mb-3">@L["PopularPositionsHeader"]</h5>
                @if (ViewBag.PopularPositions.Count == 0)
                {
                    <p class="text-muted">@L["NoPositionsYet"]</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var position in ViewBag.PopularPositions)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center gap-2">
                                <a asp-controller="Positions"
                                   asp-action="Details"
                                   asp-route-id="@position.Id"
                                   class="text-decoration-none fw-bold">
                                    @position.Title
                                </a>
                                <span class="badge bg-success rounded-pill flex-shrink-0">
                                    @position.Cvs.Count CV
                                </span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

</div>

<div class="row g-4">
    <div class="col-12">
        <div class="card shadow">
            <div class="card-body">
                <h5 class="card-title mb-3">@L["PopularTagsHeader"]</h5>
                @if (ViewBag.PositionTags.Count == 0)
                {
                    <p class="text-muted">@L["NoTagsYet"]</p>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        @foreach (var tagItem in ViewBag.PositionTags)
                        {
                            var fontSize = tagItem.Count == 1 ? "0.8rem" :
                                          tagItem.Count == 2 ? "1rem" :
                                          tagItem.Count <= 4 ? "1.2rem" : "1.5rem";

                            <a asp-controller="Positions"
                               asp-action="Index"
                               class="badge bg-info text-dark text-decoration-none"
                               style="font-size:@fontSize">
                                @tagItem.Tag
                                <span class="ms-1 opacity-75">(@tagItem.Count)</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (!User.Identity!.IsAuthenticated)
{
    <div class="card shadow mt-4 border-primary">
        <div class="card-body text-center p-4">
            <h4>@L["ReadyToStartHeader"]</h4>
            <p class="text-muted">
                @L["ReadyToStartText"]
            </p>
            <a asp-controller="Account"
               asp-action="Register"
               class="btn btn-primary me-2">
                @L["RegisterButton"]
            </a>
            <a asp-controller="Positions"
               asp-action="Index"
               class="btn btn-outline-primary">
                @L["ViewPositionsBtn"]
            </a>
        </div>
    </div>
}
