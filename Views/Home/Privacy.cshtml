@using Microsoft.Extensions.Localization
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@{
    ViewData["Title"] = L["PrivacyPolicyTitle"];
}
<h1>@ViewData["Title"]</h1>

<div class="card shadow mt-3">
    <div class="card-body">
        <h4>@L["PrivacyCollectTitle"]</h4>
        <p>@L["PrivacyCollectText"]</p>

        <h4>@L["PrivacyCookiesTitle"]</h4>
        <p>@L["PrivacyCookiesText"]</p>

        <h4>@L["PrivacyRightsTitle"]</h4>
        <p>@L["PrivacyRightsText"]</p>

        <h4>@L["PrivacySecurityTitle"]</h4>
        <p>@L["PrivacySecurityText"]</p>

        <h4>@L["PrivacyContactTitle"]</h4>
        <p>@L["PrivacyContactText"]</p>

        <hr />
        <p class="text-muted small">
            @string.Format(L["PrivacyFooterText"].Value, DateTime.Now.Year)
        </p>
    </div>
</div>