@using CvManagementSystem.Entities
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@model CvManagementSystem.ViewModels.CvViewModel
@{
    ViewData["Title"] = L["CreateCvTitle"] + " — " + Model.CandidateFullName;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@L["CreateCvTitle"] — @Model.PositionTitle</h2>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Candidate") || User.IsInRole("Administrator"))
        {
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm(@Json.Serialize(L["DeleteCvConfirm"].Value))">
                <button type="submit" class="btn btn-outline-danger btn-sm">
                    @L["DeleteCvButtonText"]
                </button>
            </form>
        }
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">@L["BackButton"]</a>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="d-flex gap-4">
            @if (!string.IsNullOrEmpty(Model.PhotoUrl))
            {
                <div class="flex-shrink-0">
                    <img src="@Model.PhotoUrl" class="img-thumbnail"
                         style="width:120px; height:120px; object-fit:cover" />
                </div>
            }
            <div class="flex-grow-1">
                <h5 class="card-title">@L["CandidateSectionTitle"]</h5>
                <table class="table table-borderless mb-0">
                    <tr>
                        <th style="width:180px">@L["NameFieldLabel"]</th>
                        <td>@Model.CandidateFullName</td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.FirstName) || !string.IsNullOrEmpty(Model.LastName))
                    {
                        <tr>
                            <th style="width:180px">@L["FirstNameLabel"] / @L["LastNameLabel"]</th>
                            <td>@Model.FirstName @Model.LastName</td>
                        </tr>
                    }
                    <tr>
                        <th>@L["EmailRow"]</th>
                        <td>@Model.CandidateEmail</td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <tr>
                            <th>@L["LocationLabel"]</th>
                            <td>@Model.Location</td>
                        </tr>
                    }
                    <tr>
                        <th>@L["PositionRow"]</th>
                        <td>@Model.PositionTitle</td>
                    </tr>
                    <tr>
                        <th>@L["CvCreatedRow"]</th>
                        <td>@Model.CreatedAt.ToString("g", System.Globalization.CultureInfo.CurrentCulture)</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <h5 class="card-title mb-4">@L["AttributesHeader"]</h5>

        @if (!Model.Attributes.Any())
        {
            <p class="text-muted">@L["NoAttributes"]</p>
        }
        else
        {
            <table class="table">
                <thead class="table-light">
                    <tr>
                        <th>@L["AttributeColumn"]</th>
                        <th>@L["ValueColumn"]</th>
                        <th>@L["StatusColumn"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var attr in Model.Attributes)
                    {
                        <tr>
                            <td>
                                <span class="fw-bold">@attr.Name</span>
                                @if (attr.IsRequired)
                                {
                                    <span class="badge bg-danger ms-1 small">@L["RequiredBadge"]</span>
                                }
                                @if (!string.IsNullOrEmpty(attr.Description))
                                {
                                    <div class="text-muted small">@attr.Description</div>
                                }
                            </td>
                            <td>
                                @if (attr.Type == AttributeType.Image && attr.HasValue)
                                {
                                    <img src="@attr.DisplayValue"
                                         class="img-thumbnail"
                                         style="max-height:100px" />
                                }
                                else if (attr.HasValue)
                                {
                                    @attr.DisplayValue
                                }
                                else
                                {
                                    @if (User.IsInRole("Candidate") || User.IsInRole("Administrator"))
                                    {
                                        <a asp-controller="Profile" asp-action="Index" class="text-warning">
                                            @L["NotFilledFillInProfile"]
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">@L["NotFilled"]</span>
                                    }
                                }
                            </td>
                            <td>
                                @if (attr.HasValue)
                                {
                                    <span class="badge bg-success">✓</span>
                                }
                                else if (attr.IsRequired)
                                {
                                    <span class="badge bg-danger">@L["StatusNotFilledWarning"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@L["StatusEmpty"]</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="card shadow">
    <div class="card-body">
        <h5 class="card-title mb-4">
            @L["ProjectsSection"]
            <span class="text-muted small fw-normal">
                @L["FilteredByTags"]
            </span>
        </h5>

        @if (!Model.Projects.Any())
        {
            <p class="text-muted">
                @L["NoMatchingProjects"]
                @if (User.IsInRole("Candidate"))
                {
                    <a asp-controller="Projects" asp-action="Create">
                        @L["AddProjectLink"]
                    </a>
                }
            </p>
        }
        else
        {
            foreach (var project in Model.Projects)
            {
                <div class="card mb-3 border-start border-primary border-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h6 class="card-title mb-1">@project.Title</h6>
                            @if (project.StartDate != null || project.EndDate != null)
                            {
                                <span class="text-muted small">
                                    @(project.StartDate ?? "?") — @(project.EndDate ?? L["PresentTime"].Value)
                                </span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(project.Description))
                        {
                            <p class="card-text text-muted small mb-2">
                                @project.Description
                            </p>
                        }
                        @foreach (var tag in project.Tags)
                        {
                            <span class="badge bg-info text-dark me-1">@tag</span>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>