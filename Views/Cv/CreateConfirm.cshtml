@using Microsoft.Extensions.Localization
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@model CvManagementSystem.ViewModels.PositionForCandidateViewModel
@{
    ViewData["Title"] = L["CreateCvTitle"];
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-body p-4 text-center">
                <h4 class="mb-3">@L["CreateCvForPosition"]</h4>
                <h3 class="text-primary mb-3">@Model.Title</h3>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted mb-3">@Model.Description</p>
                }

                <div class="mb-3">
                    @foreach (var tag in Model.Tags)
                    {
                        <span class="badge bg-info text-dark me-1">@tag</span>
                    }
                </div>

                <p class="text-muted small mb-4">
                    @Html.Raw(L["CvAutoGenerationWarning", Model.AttributesCount])
                </p>

                <form asp-action="Create" method="post">
                    <input type="hidden" name="positionId" value="@Model.Id" />
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="submit" class="btn btn-primary">
                            @L["CreateCvButton"]
                        </button>
                        <a asp-action="Positions" class="btn btn-outline-secondary">
                            @L["CancelButton"]
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>