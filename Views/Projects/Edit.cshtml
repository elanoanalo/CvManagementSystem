@using Microsoft.Extensions.Localization
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@model CvManagementSystem.ViewModels.ProjectFormViewModel
@{
    ViewData["Title"] = L["EditProjectTitle"];
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="mb-4">@L["EditProjectHeader"]</h2>

                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">@L["ProjectTitleLabel"]</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">
                            @L["ProjectDescriptionLabel"]
                        </label>
                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label">@L["StartDateLabel"]</label>
                            <input asp-for="StartDate"
                                   type="date"
                                   class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label">
                                @L["EndDateLabel"]
                                <span class="text-muted small">@L["EndDateHint"]</span>
                            </label>
                            <input asp-for="EndDate"
                                   type="date"
                                   class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">@L["TechnologyTagsLabel"]</label>
                        <div id="tagsList" class="mb-2 d-flex flex-wrap gap-2">
                            @for (int i = 0; i < Model.Tags.Count; i++)
                            {
                                <div class="d-inline-flex align-items-center tag-item">
                                    <input type="hidden"
                                           name="Tags[@i]"
                                           value="@Model.Tags[i]" />
                                    <span class="badge bg-info text-dark me-1">
                                        @Model.Tags[i]
                                        <button type="button"
                                                class="btn-close btn-close-white ms-1"
                                                style="font-size:0.6rem">
                                        </button>
                                    </span>
                                </div>
                            }
                        </div>
                        <div class="input-group">
                            <input type="text"
                                   id="newTagInput"
                                   class="form-control"
                                   placeholder="@L["NewTagPlaceholder"]" />
                            <button type="button"
                                    id="addTagBtn"
                                    class="btn btn-outline-primary">
                                @L["AddTagBtn"]
                            </button>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@L["SaveBtn"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["CancelBtn"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var tagCount = @Model.Tags.Count;

        // Локализованные строки для JavaScript
        var jsTagLengthError = @Json.Serialize(L["JsTagLengthError"].Value);
        var jsMaxTagsError = @Json.Serialize(L["JsMaxTagsError"].Value);

        function addTag() {
            var input = document.getElementById('newTagInput');
            var value = input.value.trim();

            if (value === '') return;

            if (value.length > 50) {
                alert(jsTagLengthError);
                return;
            }

            var currentTags = document.querySelectorAll('.tag-item').length;
            if (currentTags >= 10) {
                alert(jsMaxTagsError);
                return;
            }

            var tagsList = document.getElementById('tagsList');
            var div = document.createElement('div');
            div.className = 'd-inline-flex align-items-center tag-item';
            div.innerHTML =
                '<input type="hidden" name="Tags[' + tagCount + ']" value="' + value + '" />' +
                '<span class="badge bg-info text-dark me-1">' + value +
                ' <button type="button" class="btn-close btn-close-white ms-1 remove-tag-btn" style="font-size:0.6rem"></button>' +
                '</span>';

            tagsList.appendChild(div);
            tagCount++;
            input.value = '';
            input.focus();
        }

        document.getElementById('addTagBtn')
            .addEventListener('click', function() { addTag(); });

        document.getElementById('newTagInput')
            .addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    addTag();
                }
            });

        document.getElementById('tagsList')
            .addEventListener('click', function(e) {
                if (e.target.classList.contains('remove-tag-btn') ||
                    e.target.classList.contains('btn-close')) {
                    e.target.closest('.tag-item').remove();
                }
            });
    </script>
}