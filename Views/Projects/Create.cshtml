@using Microsoft.Extensions.Localization
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@model CvManagementSystem.ViewModels.ProjectFormViewModel
@{
    ViewData["Title"] = L["CreateProjectTitle"];
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="mb-4">@L["CreateProjectHeader"]</h2>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">@L["ProjectTitleLabel"]</label>
                        <input asp-for="Title"
                               class="form-control"
                               placeholder="@L["ProjectTitlePlaceholder"]" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">
                            @L["ProjectDescriptionLabel"]
                        </label>
                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"
                                  placeholder="@L["ProjectDescriptionPlaceholder"]"></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label">@L["StartDateLabel"]</label>
                            <input asp-for="StartDate"
                                   type="date"
                                   class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label">
                                @L["EndDateLabel"]
                                <span class="text-muted small">@L["EndDateHint"]</span>
                            </label>
                            <input asp-for="EndDate"
                                   type="date"
                                   class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">@L["TechnologyTagsLabel"]</label>
                        <div id="tagsList" class="mb-2 d-flex flex-wrap gap-2"></div>
                        <div class="input-group">
                            <input type="text"
                                   id="newTagInput"
                                   class="form-control"
                                   placeholder="@L["NewTagPlaceholder"]" />
                            <button type="button"
                                    id="addTagBtn"
                                    class="btn btn-outline-primary">
                                @L["AddTagBtn"]
                            </button>
                        </div>
                        <small class="text-muted">
                            @L["TagsHint"]
                        </small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@L["SaveBtn"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["CancelBtn"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/tag-input.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initTagInput({
                maxTags: 10,
                maxTagLength: 50,
                duplicateMessage: '@Html.Raw(L["JsTagDuplicateError"].Value)',
                lengthMessage: '@Html.Raw(L["JsTagLengthError"].Value)',
                maxMessage: '@Html.Raw(L["JsMaxTagsError"].Value)'
            });
        });
    </script>
}