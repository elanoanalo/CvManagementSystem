@using CvManagementSystem.ViewModels
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@model IEnumerable<ProjectListViewModel>
@{
    ViewData["Title"] = L["MyProjectsTitle"];
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@L["MyProjectsHeader"]</h2>
    <a asp-action="Create" class="btn btn-primary">@L["AddProjectBtn"]</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        @L["NoProjectsAlert"]
    </div>
}
else
{
    <div class="mb-2 d-flex gap-2 align-items-center" style="height:36px">
        <button type="button"
                id="deleteSelectedBtn"
                class="btn btn-danger btn-sm"
                style="visibility:hidden; opacity:0; transition: opacity 0.2s ease;">
            @L["DeleteSelectedBtn"]
        </button>
        <span id="selectedCount" class="text-muted small"></span>
    </div>

    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th style="width:40px">
                    <input type="checkbox" id="selectAll" class="form-check-input" />
                </th>
                <th>@L["TitleColumn"]</th>
                <th>@L["DescriptionColumn"]</th>
                <th>@L["PeriodColumn"]</th>
                <th>@L["TagsColumn"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in Model)
            {
                <tr class="clickable-row"
                    data-href="@Url.Action("Edit", new { id = project.Id })">
                    <td onclick="event.stopPropagation()">
                        <input type="checkbox"
                               class="form-check-input row-checkbox"
                               value="@project.Id" />
                    </td>
                    <td class="fw-bold">@project.Title</td>
                    <td>
                        @if (!string.IsNullOrEmpty(project.Description))
                        {
                            @(project.Description.Length > 50
                                ? project.Description.Substring(0, 50) + "..."
                                : project.Description)
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        @if (project.StartDate != null || project.EndDate != null)
                        {
                            <span>@(project.StartDate ?? "?") — @(project.EndDate ?? L["PresentTimeValue"].Value)</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        @foreach (var tag in project.Tags)
                        {
                            <span class="badge bg-info text-dark me-1">@tag</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        var jsSelectedPrefix = @Json.Serialize(L["JsSelectedPrefix"].Value);
        var jsConfirmDeleteStart = @Json.Serialize(L["JsConfirmDeleteStart"].Value);
        var jsConfirmDeletePcs = @Json.Serialize(L["JsConfirmDeletePcs"].Value);
        var jsConfirmDeleteEnd = @Json.Serialize(L["JsConfirmDeleteEnd"].Value);

        document.querySelectorAll('.clickable-row').forEach(function(row) {
            row.style.cursor = 'pointer';
            row.addEventListener('click', function() {
                window.location.href = this.getAttribute('data-href');
            });
        });

        document.getElementById('selectAll')
            .addEventListener('change', function() {
                document.querySelectorAll('.row-checkbox').forEach(function(cb) {
                    cb.checked = this.checked;
                }.bind(this));
                updateToolbar();
            });

        document.querySelectorAll('.row-checkbox').forEach(function(cb) {
            cb.addEventListener('change', function() {
                updateToolbar();
            });
        });

        document.getElementById('deleteSelectedBtn')
            .addEventListener('click', function() {
                deleteSelected();
            });

        function updateToolbar() {
            var selected = document.querySelectorAll('.row-checkbox:checked');
            var deleteBtn = document.getElementById('deleteSelectedBtn');
            var countSpan = document.getElementById('selectedCount');

            if (selected.length > 0) {
                deleteBtn.style.visibility = 'visible';
                deleteBtn.style.opacity = '1';
                countSpan.textContent = jsSelectedPrefix + selected.length;
            } else {
                deleteBtn.style.visibility = 'hidden';
                deleteBtn.style.opacity = '0';
                countSpan.textContent = '';
            }
        }

        function deleteSelected() {
            var selected = document.querySelectorAll('.row-checkbox:checked');
            if (selected.length === 0) return;

            if (!confirm(jsConfirmDeleteStart + selected.length + jsConfirmDeletePcs + jsConfirmDeleteEnd))
                return;

            var form = document.createElement('form');
            form.method = 'post';
            form.action = '/Projects/DeleteMultiple';

            selected.forEach(function(cb) {
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'ids';
                input.value = cb.value;
                form.appendChild(input);
            });

            document.body.appendChild(form);
            form.submit();
        }
    </script>
}