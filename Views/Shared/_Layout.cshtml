<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CV Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom border-body mb-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    CV Management
                </a>
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Attributes"
                                       asp-action="Index">
                                        Атрибуты
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Positions"
                                       asp-action="Index">
                                        Позиции
                                    </a>
                                </li>
                            }

@if (User.IsInRole("Candidate") || User.IsInRole("Administrator"))
{
    <li class="nav-item">
        <a class="nav-link"
           asp-controller="Profile"
           asp-action="Index">
            Мой профиль
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link"
           asp-controller="Projects"
           asp-action="Index">
            Мои проекты
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link"
           asp-controller="Cv"
           asp-action="Index">
            Мои CV
        </a>
    </li>
}
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light">
                                    @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account"
                                      asp-action="Logout"
                                      method="post">
                                    <button type="submit"
                                            class="btn btn-outline-light btn-sm mt-1">
                                        Выйти
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    Войти
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    Регистрация
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-3">
        <div class="container text-center">
            <span>CV Management System &copy; @DateTime.Now.Year</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>