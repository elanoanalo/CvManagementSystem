<!DOCTYPE html>
<html lang="@System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName" id="htmlRoot">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CV Management</title>

    @* Применяем тему ДО загрузки CSS — чтобы не было мигания *@
    <script>
            var t = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', t);
    </script>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom border-body mb-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    CV Management
                </a>
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto">
                        @* Позиции видят все — и незалогиненные тоже *@
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Positions" asp-action="Index">
                                Позиции
                            </a>
                        </li>

                        @if (User.Identity!.IsAuthenticated)
                        {
                            @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Attributes" asp-action="Index">
                                        Атрибуты
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Candidate") || User.IsInRole("Administrator"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                        Мой профиль
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Projects" asp-action="Index">
                                        Мои проекты
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Cv" asp-action="Index">
                                        Мои CV
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @* Переключатель темы *@
                        <li class="nav-item me-2">
                            <button id="themeToggle"
                                    class="btn btn-outline-light btn-sm mt-1"
                                    title="Переключить тему">
                                🌙
                            </button>
                        </li>

                        @* Переключатель языка — вот сюда! *@
                        <li class="nav-item me-2">
                            <div class="dropdown">
                                <button class="btn btn-outline-light btn-sm mt-1 dropdown-toggle"
                                        data-bs-toggle="dropdown">
                                    🌐 @System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName.ToUpper()
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Account"
                                           asp-action="SetLanguage"
                                           asp-route-culture="en"
                                           asp-route-returnUrl="@Context.Request.Path">
                                            🇬🇧 English
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Account"
                                           asp-action="SetLanguage"
                                           asp-route-culture="ru"
                                           asp-route-returnUrl="@Context.Request.Path">
                                            🇷🇺 Русский
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </li>

                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light">
                                    @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account"
                                      asp-action="Logout"
                                      method="post">
                                    <button type="submit"
                                            class="btn btn-outline-light btn-sm mt-1">
                                        Выйти
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    Войти
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    Регистрация
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-3">
        <div class="container text-center">
            <span>CV Management System &copy; @DateTime.Now.Year</span>
            <span class="mx-2">|</span>
            <span>Developed by Abay Tolegen</span>
            <span class="mx-2">|</span>
            <span>No rights reserved whatsoever 🙂</span>
            <span class="mx-2">|</span>
            <a asp-controller="Home" asp-action="Privacy" class="text-muted">
                Privacy Policy
            </a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
            // Применяем тему при загрузке страницы
            var savedTheme = localStorage.getItem('theme') || 'light';
            document.getElementById('htmlRoot').setAttribute('data-bs-theme', savedTheme);
            updateThemeButton(savedTheme);

            function updateThemeButton(theme) {
                var btn = document.getElementById('themeToggle');
                if (btn) {
                    btn.textContent = theme === 'dark' ? '☀️' : '🌙';
                    btn.title = theme === 'dark' ? 'Светлая тема' : 'Тёмная тема';
                }
            }

            document.getElementById('themeToggle')
                .addEventListener('click', function () {
                    var html = document.getElementById('htmlRoot');
                    var current = html.getAttribute('data-bs-theme') || 'light';
                    var next = current === 'dark' ? 'light' : 'dark';

                    html.setAttribute('data-bs-theme', next);
                    localStorage.setItem('theme', next);
                    updateThemeButton(next);
                });
    </script>
</body>
</html>