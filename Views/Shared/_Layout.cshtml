@using Microsoft.Extensions.Localization
@inject IStringLocalizer<CvManagementSystem.LocalizationMarker> L
@{
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}
<!DOCTYPE html>
<html lang="@System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName" id="htmlRoot">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CV Management</title>

    <script>
            var t = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', t);
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-xl navbar-dark bg-dark border-bottom border-body mb-3">
            <div class="container-fluid px-xl-5">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    CV Management
                </a>
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-xl-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Positions" asp-action="Index">
                                @L["Positions"]
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Attributes" asp-action="Index">
                                        @L["Attributes"]
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Candidate") || User.IsInRole("Administrator"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                        @L["MyProfile"]
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Projects" asp-action="Index">
                                        @L["MyProjects"]
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Cv" asp-action="Index">
                                        @L["MyCVs"]
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <form asp-controller="Search" asp-action="Index" method="get"
                          class="d-flex mx-xl-3 my-2 my-xl-0" role="search" style="max-width: 250px; width: 100%;">
                        <input type="search"
                               name="query"
                               class="form-control form-control-sm"
                               placeholder="@L["SearchPlaceholder"]"
                               value="@(Context.Request.Query["query"])" />
                        <button type="submit" class="btn btn-outline-light btn-sm ms-1">
                            🔍
                        </button>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-xl-center">
                        <li class="nav-item me-xl-2 my-1 my-xl-0">
                            <button id="themeToggle"
                                    class="btn btn-outline-light btn-sm"
                                    title="Переключить тему">
                                🌙
                            </button>
                        </li>

                        <li class="nav-item me-xl-3 my-1 my-xl-0">
                            <div class="dropdown">
                                <button class="btn btn-outline-light btn-sm dropdown-toggle"
                                        data-bs-toggle="dropdown">
                                    🌐 @System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName.ToUpper()
                                </button>
                                <ul class="dropdown-menu dropdown-menu-xl-end">
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Account"
                                           asp-action="SetLanguage"
                                           asp-route-culture="en"
                                           asp-route-returnUrl="@returnUrl">
                                            🇬🇧 English
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Account"
                                           asp-action="SetLanguage"
                                           asp-route-culture="ru"
                                           asp-route-returnUrl="@returnUrl">
                                            🇷🇺 Русский
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown d-flex align-items-center my-1 my-xl-0">
                                <a class="nav-link dropdown-toggle text-light px-0 me-3" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    👤 @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-xl-end">
                                    @if (User.IsInRole("Administrator"))
                                    {
                                        <li>
                                            <a class="dropdown-item fw-bold text-danger" asp-controller="Admin" asp-action="Index">
                                                ⚙️ @L["AdminNavLink"]
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                                            <button type="submit" class="dropdown-item">
                                                🚪 @L["Logout"]
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item my-1 my-xl-0 me-xl-2">
                                <a class="btn btn-outline-light btn-sm"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    @L["Login"]
                                </a>
                            </li>
                            <li class="nav-item my-1 my-xl-0">
                                <a class="btn btn-light btn-sm"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    @L["Register"]
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-3">
        <div class="container text-center">
            <span>CV Management System &copy; @DateTime.Now.Year</span>
            <span class="mx-2">|</span>
            <span>@L["DevelopedBy"] Abay Tolegen</span>
            <span class="mx-2">|</span>
            <span>@L["NoRightsReserved"] 🙂</span>
            <span class="mx-2">|</span>
            <a asp-controller="Home" asp-action="Privacy" class="text-muted">
                @L["PrivacyPolicy"]
            </a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
            function updateThemeButton(theme) {
                var btn = document.getElementById('themeToggle');
                if (btn) {
                    btn.textContent = theme === 'dark' ? '☀️' : '🌙';
                    btn.title = theme === 'dark' ? 'Светлая тема' : 'Тёмная тема';
                }
            }

            document.addEventListener('DOMContentLoaded', function () {
                var savedTheme = localStorage.getItem('theme') || 'light';
                updateThemeButton(savedTheme);

                var toggleBtn = document.getElementById('themeToggle');
                if (toggleBtn) {
                    toggleBtn.addEventListener('click', function () {
                        var html = document.documentElement;
                        var current = html.getAttribute('data-bs-theme') || 'light';
                        var next = current === 'dark' ? 'light' : 'dark';

                        html.setAttribute('data-bs-theme', next);
                        localStorage.setItem('theme', next);
                        updateThemeButton(next);
                    });
                }
            });
    </script>
</body>
</html>